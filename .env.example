# Environment
ENV=development
DEBUG=True

# Database
DATABASE_URL=postgresql://localhost/junior_counsel_dev
TEST_DATABASE_URL=postgresql://localhost/junior_counsel_test

# Redis/Queue
REDIS_URL=redis://localhost:6379/0

# Authentication
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=noreply@juniorcounsel.co.za

# AI Providers (to be configured)
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# File Storage
UPLOAD_FOLDER=/path/to/uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,doc,jpg,png

# Application
APP_NAME=Junior Counsel
APP_URL=http://localhost:8000
