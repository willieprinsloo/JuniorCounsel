# Environment
ENV=development
DEBUG=True

# Database
DATABASE_URL=postgresql://localhost/junior_counsel_dev
TEST_DATABASE_URL=postgresql://localhost/junior_counsel_test

# Redis/Queue
REDIS_URL=redis://localhost:6379/0

# Authentication (Phase 2 - FastAPI)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30  # FastAPI convention (minutes, not hours)

# CORS (Phase 2 - FastAPI)
# Comma-separated list of allowed origins for frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email (Phase 3 - Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM_ADDRESS=noreply@juniorcounsel.co.za

# AI Providers (Phase 3 - to be configured)
# OPENAI_API_KEY=your-openai-key
# ANTHROPIC_API_KEY=your-anthropic-key

# File Storage (Phase 2 + Phase 3)
UPLOAD_FOLDER=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,doc,jpg,png,jpeg,txt

# Application (Phase 2 - FastAPI)
APP_NAME=Junior Counsel
APP_URL=http://localhost:8000
# Uvicorn settings
RELOAD=true  # Auto-reload on code changes (development only)
